{
  "name": "outsignal-agents",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "_comment_build": "build uses Turbopack (Next 16). build:webpack is the manual rollback if Turbopack regresses on Vercel — Next.js still ships the webpack pipeline, only the build engine differs.",
    "dev": "next dev",
    "build": "next build --turbopack",
    "build:webpack": "next build",
    "postbuild": "node -e \"const fs=require('fs'); const expected=['client-sweep.js','campaign-create.js','kb-search.js','sender-health.js','discovery-promote.js','workspace-intelligence.js','domain-health.js']; for (const f of expected) fs.statSync('dist/cli/'+f);\"",
    "postinstall": "prisma generate && npm run build:cli && npm run build:dev-cli",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "chat": "tsx scripts/chat.ts",
    "build:cli": "tsup --config tsup.cli.config.ts",
    "build:dev-cli": "tsup --config tsup.dev-cli.config.ts",
    "monty": "tsx scripts/monty.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/react": "^3.0.99",
    "@dnd-kit/core": "^6.3.1",
    "@mendable/firecrawl-js": "^4.13.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/client": "^6.19.2",
    "@react-pdf/renderer": "^4.3.2",
    "@slack/web-api": "^7.14.1",
    "@trigger.dev/build": "^4.4.3",
    "@trigger.dev/sdk": "^4.4.3",
    "ai": "^6.0.97",
    "apify-client": "^2.22.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "^3.3.1",
    "fetch-socks": "^1.3.3",
    "geist": "^1.7.0",
    "googleapis": "^171.4.0",
    "handlebars": "^4.7.8",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.8",
    "openai": "^6.25.0",
    "pdf-parse": "^2.4.5",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.2",
    "sonner": "^2.0.7",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.5.0",
    "use-debounce": "^10.1.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "prisma": "^6.19.2",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
